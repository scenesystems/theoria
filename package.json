{
  "name": "theoria",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/scenesystems/theoria",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "prepare": "husky",
    "check": "tsc -b tsconfig.json",
    "check:tests": "tsc -b tsconfig.test.json",
    "check:all": "bun run check && bun run check:tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --max-warnings=0",
    "lint:fix": "eslint --max-warnings=0 --fix",
    "build": "tsc -b tsconfig.build.json && bun run --filter '*' build && bun run scripts/resolve-workspace-deps.ts",
    "clean": "rm -rf packages/*/build packages/*/dist packages/*/.tsbuildinfo apps/*/.tsbuildinfo *.tsbuildinfo",
    "docgen": "bun run --filter '*' docgen",
    "docs": "bun run docgen && bun scripts/docs.ts",
    "docs:preview": "bun scripts/docs.ts && docker build -t theoria-docs docs && docker run --rm -p 4000:4000 -v \"$PWD/docs:/site\" theoria-docs",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prettier": "prettier --cache --cache-location node_modules/.cache/.prettiercache --check \"**/*.{md,json,yml,yaml}\"",
    "prettier:fix": "prettier --cache --cache-location node_modules/.cache/.prettiercache --write \"**/*.{md,json,yml,yaml}\"",
    "app:theoria": "bun run --filter @theoria/theoria-app dev",
    "app:theoria:tmux": "bash scripts/dev-theoria-tmux.sh start",
    "app:theoria:tmux:logs": "bash scripts/dev-theoria-tmux.sh logs",
    "app:theoria:tmux:logs:full": "bash scripts/dev-theoria-tmux.sh logs-full",
    "app:theoria:tmux:stop": "bash scripts/dev-theoria-tmux.sh stop",
    "check:apps": "bun run --filter @theoria/theoria-app check:all",
    "lint:apps": "bun run --filter @theoria/theoria-app lint",
    "test:apps": "bun run --filter @theoria/theoria-app test",
    "vendor:sync": "bash scripts/vendor-sync.sh",
    "vendor:check": "bash scripts/vendor-sync.sh --check",
    "test:e2e:theoria": "playwright test --config e2e/theoria/playwright.config.ts"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/ai": "0.35.0",
    "@effect/ai-anthropic": "0.25.0",
    "@effect/ai-openai": "0.39.0",
    "@effect/ai-openrouter": "0.10.0",
    "@effect/build-utils": "^0.8.9",
    "@effect/docgen": "^0.5.2",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/experimental": "0.60.0",
    "@effect/language-service": "^0.81.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-bun": "0.89.0",
    "@effect/rpc": "0.75.0",
    "@effect/sql": "0.51.0",
    "@effect/sql-sqlite-node": "0.52.0",
    "@effect/vitest": "^0.29.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "^3.2.4",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "bun-types": "^1.3.4",
    "effect": "3.21.0",
    "eslint": "^9.39.1",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "effect": "3.21.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-bun": "0.89.0",
    "@effect/ai": "0.35.0",
    "@effect/ai-anthropic": "0.25.0",
    "@effect/ai-openai": "0.39.0",
    "@effect/ai-openrouter": "0.10.0",
    "@effect/rpc": "0.75.0"
  },
  "lint-staged": {
    "*.{ts,mts}": [
      "eslint --max-warnings=0 --fix"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
