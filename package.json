{
  "name": "theoria",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/scenesystems/theoria",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "check": "tsc -b tsconfig.json",
    "check:tests": "tsc --noEmit -p tsconfig.test.json",
    "check:all": "bun run check && bun run check:tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'No packages to lint yet — add per-package eslint targets as packages are created'",
    "build": "echo 'No packages to build yet — add per-package build targets as packages are created'",
    "clean": "rm -rf packages/*/build packages/*/dist packages/*/.tsbuildinfo *.tsbuildinfo",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prettier": "prettier --cache --cache-location node_modules/.cache/.prettiercache --check \"**/*.{md,json,yml,yaml}\"",
    "prettier:fix": "prettier --cache --cache-location node_modules/.cache/.prettiercache --write \"**/*.{md,json,yml,yaml}\""
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@effect/language-service": "^0.81.0",
    "@effect/vitest": "^0.29.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "effect": "3.21.0",
    "@effect/experimental": "0.60.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-bun": "0.89.0"
  },
  "lint-staged": {
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
