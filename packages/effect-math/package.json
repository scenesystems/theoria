{
  "name": "effect-math",
  "version": "0.0.0",
  "type": "module",
  "description": "Foundational numerics, linear algebra, statistics, and optimization for Effect",
  "license": "MIT",
  "homepage": "https://github.com/scenesystems/theoria/tree/main/packages/effect-math",
  "repository": {
    "type": "git",
    "url": "https://github.com/scenesystems/theoria.git",
    "directory": "packages/effect-math"
  },
  "bugs": {
    "url": "https://github.com/scenesystems/theoria/issues"
  },
  "keywords": [
    "effect",
    "numerics",
    "linear-algebra",
    "statistics",
    "probability",
    "optimization",
    "mathematics",
    "scientific-computing",
    "pareto",
    "kde"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    },
    "./experimental": {
      "types": "./dist/experimental/index.d.ts",
      "default": "./dist/experimental/index.js"
    },
    "./Numeric": {
      "types": "./dist/Numeric/index.d.ts",
      "default": "./dist/Numeric/index.js"
    },
    "./Algebra": {
      "types": "./dist/Algebra/index.d.ts",
      "default": "./dist/Algebra/index.js"
    },
    "./LinearAlgebra": {
      "types": "./dist/LinearAlgebra/index.d.ts",
      "default": "./dist/LinearAlgebra/index.js"
    },
    "./Calculus": {
      "types": "./dist/Calculus/index.d.ts",
      "default": "./dist/Calculus/index.js"
    },
    "./Special": {
      "types": "./dist/Special/index.d.ts",
      "default": "./dist/Special/index.js"
    },
    "./Probability": {
      "types": "./dist/Probability/index.d.ts",
      "default": "./dist/Probability/index.js"
    },
    "./Statistics": {
      "types": "./dist/Statistics/index.d.ts",
      "default": "./dist/Statistics/index.js"
    },
    "./Optimization": {
      "types": "./dist/Optimization/index.d.ts",
      "default": "./dist/Optimization/index.js"
    },
    "./Geometry": {
      "types": "./dist/Geometry/index.d.ts",
      "default": "./dist/Geometry/index.js"
    },
    "./internal/*": null,
    "./Numeric/internal/*": null,
    "./Algebra/internal/*": null,
    "./LinearAlgebra/internal/*": null,
    "./Calculus/internal/*": null,
    "./Special/internal/*": null,
    "./Probability/internal/*": null,
    "./Statistics/internal/*": null,
    "./Optimization/internal/*": null,
    "./Geometry/internal/*": null
  },
  "scripts": {
    "check": "tsc -b tsconfig.src.json",
    "check:tests": "tsc -b tsconfig.test.json",
    "check:tests:target-state": "tsc -b tsconfig.test.target-state.json",
    "lint": "eslint --max-warnings=0 src test",
    "lint:fix": "eslint --max-warnings=0 --fix src test",
    "test": "vitest run --root ../.. packages/effect-math/test/architecture packages/effect-math/test/contracts packages/effect-math/test/smoke",
    "test:target-state": "bun run --cwd ../.. test:target-state",
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "peerDependencies": {
    "effect": "^3.0.0"
  }
}
