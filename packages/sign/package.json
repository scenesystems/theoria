{
  "name": "@scenesystems/sign",
  "version": "0.1.0",
  "type": "module",
  "description": "Digital signatures, key agreement, and key encapsulation for Effect",
  "license": "MIT",
  "homepage": "https://github.com/scenesystems/theoria/tree/main/packages/sign",
  "repository": {
    "type": "git",
    "url": "https://github.com/scenesystems/theoria.git",
    "directory": "packages/sign"
  },
  "bugs": {
    "url": "https://github.com/scenesystems/theoria/issues"
  },
  "keywords": [
    "effect",
    "ed25519",
    "secp256k1",
    "x25519",
    "ecdsa",
    "ecdh",
    "ml-dsa",
    "slh-dsa",
    "post-quantum",
    "digital-signature",
    "key-agreement",
    "key-encapsulation",
    "xwing",
    "ml-kem"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "directory": "dist"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check": "tsc -b tsconfig.src.json",
    "check:tests": "tsc -b tsconfig.test.json",
    "lint": "eslint --max-warnings=0 src test",
    "lint:fix": "eslint --max-warnings=0 --fix src test",
    "test": "vitest run --root ../.. packages/sign/test",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build": "bun run build-esm && bun run build-annotate && bun run build-cjs && build-utils pack-v3",
    "clean": "rm -rf build dist .tsbuildinfo",
    "docgen": "docgen"
  },
  "dependencies": {
    "@noble/curves": "^2.0.0",
    "@noble/hashes": "^2.0.0",
    "@noble/post-quantum": "^0.5.0"
  },
  "devDependencies": {
    "@theoria/source-proof": "workspace:*"
  },
  "peerDependencies": {
    "effect": "^3.20.0"
  }
}
