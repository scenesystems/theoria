{
  "name": "@scenesystems/seal",
  "version": "0.0.0",
  "type": "module",
  "description": "Authenticated encryption for Effect",
  "license": "MIT",
  "homepage": "https://github.com/scenesystems/theoria/tree/main/packages/seal",
  "repository": {
    "type": "git",
    "url": "https://github.com/scenesystems/theoria.git",
    "directory": "packages/seal"
  },
  "bugs": {
    "url": "https://github.com/scenesystems/theoria/issues"
  },
  "keywords": [
    "effect",
    "xchacha20",
    "poly1305",
    "aes-gcm",
    "aes-gcm-siv",
    "aead",
    "encryption",
    "authenticated-encryption",
    "noble-ciphers",
    "sealed-envelope"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "check": "tsc -b tsconfig.src.json",
    "check:tests": "tsc -b tsconfig.test.json",
    "lint": "eslint --max-warnings=0 src test",
    "lint:fix": "eslint --max-warnings=0 --fix src test",
    "test": "vitest run",
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@noble/ciphers": "^2.0.0",
    "@scure/base": "^2.0.0"
  },
  "peerDependencies": {
    "effect": "^3.0.0"
  }
}
