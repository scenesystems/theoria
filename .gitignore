# Dependencies
node_modules/

# Build artifacts
build/
dist/
out/
*.tgz

# Emitted JS in source/test directories (build output goes to dist/)
packages/*/src/**/*.js
packages/*/test/**/*.js

# TypeScript incremental build
.tsbuildinfo/
*.tsbuildinfo

# Generated documentation (@effect/docgen output per-package)
packages/*/docs/

# Aggregated docs site (generated content excluded, infrastructure tracked)
/docs/_effect/
/docs/_scenesystems/
/docs/index.md
/docs/_site/
/docs/.jekyll-cache/

# Code coverage
coverage/
*.lcov
e2e/*/test-results/
playwright-report/

# Environment variables
.env
.env.local
.env.*.local

# Python (uv fixture generation)
__pycache__/
.venv/

# Caches
.eslintcache
.cache

# OS
.DS_Store

# IDE
.idea/

# Scratch files
.tmp/

# PR-scoped specs (ephemeral tracking — not committed)
.specs/*
!.specs/AGENTS.md

# Railway CLI local link state
.railway/

# Vendored source (agent reference — cloned by scripts/vendor-sync.sh)
.vendor/effect/
.vendor/noble-hashes/
.vendor/noble-curves/
.vendor/noble-ciphers/
.vendor/noble-post-quantum/
.vendor/scure-base/
