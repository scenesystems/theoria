#!/usr/bin/env sh

set -e

echo "═══════════════════════════════════════════"
echo "  Theoria Pre-commit Quality Checks"
echo "═══════════════════════════════════════════"

# 1. Lint & Format staged files
echo ""
echo "[1/3] Linting and formatting staged files..."
bunx lint-staged
echo "Lint and format passed"

# 2. Type checking
echo ""
echo "[2/3] Type checking (src + tests)..."
if ! bun run check:all; then
  echo "FAILED: Type errors found. Fix before committing."
  exit 1
fi
echo "Type check passed"

# 3. Tests
echo ""
echo "[3/3] Running tests..."
if ! bun run test; then
  echo "FAILED: Test failures found. Fix before committing."
  exit 1
fi
echo "Tests passed"

echo ""
echo "═══════════════════════════════════════════"
echo "  All pre-commit checks passed!"
echo "═══════════════════════════════════════════"
