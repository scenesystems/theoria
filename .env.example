# Theoria app runtime configuration
# Copy to .env and fill in values for local or production-like runs.

# App server
PORT=3876
BUILD_SHA=dev-local

# Demo execution policy
THEORIA_LOCAL_CONCURRENCY=8
THEORIA_PROVIDER_CONCURRENCY=2
THEORIA_LOCAL_TIMEOUT_MS=5000
THEORIA_PROVIDER_TIMEOUT_MS=20000

# Provider selection (openai | anthropic | openrouter)
DSP_PROVIDER=openai
DSP_PROVIDER_MODEL=gpt-4o-mini

# Provider API keys (set the one matching your DSP_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
