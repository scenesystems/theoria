# effect-dsp examples — LLM provider configuration
# Copy to .env and fill in your keys.

# Provider selection (openai | anthropic | openrouter)
DSP_PROVIDER=openai
DSP_PROVIDER_MODEL=gpt-4o-mini

# Provider API keys (set the one matching your DSP_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Optional: override per-provider defaults
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_URL=https://api.openai.com/v1
