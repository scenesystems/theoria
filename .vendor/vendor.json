{
  "description": "Vendored source repos for agent reference. Shallow-cloned, gitignored, version-pinned.",
  "subtrees": {
    "effect": {
      "remote": "https://github.com/Effect-TS/effect.git",
      "prefix": ".vendor/effect",
      "tagTemplate": "effect@${version}",
      "versionSource": "node_modules/effect/package.json",
      "currentVersion": "3.21.0",
      "currentTag": "effect@3.21.0",
      "description": "Effect-TS monorepo \u2014 all @effect/* packages. Tag anchored to core effect version."
    },
    "noble-hashes": {
      "remote": "https://github.com/paulmillr/noble-hashes.git",
      "prefix": ".vendor/noble-hashes",
      "tagTemplate": "${version}",
      "versionSource": "packages/digest/node_modules/@noble/hashes/package.json",
      "currentVersion": "2.0.1",
      "currentTag": "2.0.1",
      "description": "Audited hash functions, MACs, KDFs. Used by digest and sign packages."
    },
    "noble-curves": {
      "remote": "https://github.com/paulmillr/noble-curves.git",
      "prefix": ".vendor/noble-curves",
      "tagTemplate": "${version}",
      "versionSource": "packages/sign/node_modules/@noble/curves/package.json",
      "currentVersion": "2.0.1",
      "currentTag": "2.0.1",
      "description": "Audited elliptic curve cryptography. Used by sign package."
    },
    "noble-ciphers": {
      "remote": "https://github.com/paulmillr/noble-ciphers.git",
      "prefix": ".vendor/noble-ciphers",
      "tagTemplate": "${version}",
      "versionSource": "packages/seal/node_modules/@noble/ciphers/package.json",
      "currentVersion": "2.1.1",
      "currentTag": "2.1.1",
      "description": "Audited symmetric ciphers (Salsa20, ChaCha, AES). Used by seal package."
    },
    "noble-post-quantum": {
      "remote": "https://github.com/paulmillr/noble-post-quantum.git",
      "prefix": ".vendor/noble-post-quantum",
      "tagTemplate": "${version}",
      "versionSource": "packages/sign/node_modules/@noble/post-quantum/package.json",
      "currentVersion": "0.5.4",
      "currentTag": "0.5.4",
      "description": "Post-quantum cryptography (ML-KEM, ML-DSA, SLH-DSA). Used by sign package."
    },
    "scure-base": {
      "remote": "https://github.com/paulmillr/scure-base.git",
      "prefix": ".vendor/scure-base",
      "tagTemplate": "${version}",
      "versionSource": "packages/digest/node_modules/@scure/base/package.json",
      "currentVersion": "2.0.0",
      "currentTag": "2.0.0",
      "description": "Audited base encoding (base64, base58, etc). Used by digest and seal packages."
    }
  }
}
