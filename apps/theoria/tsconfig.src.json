{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["@types/node", "bun-types", "vite/client"],
    "tsBuildInfoFile": ".tsbuildinfo/src.tsbuildinfo"
  },
  "include": [
    "server.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "vite.config.ts",
    "../../packages/effect-inference/src/**/*.ts"
  ]
}
