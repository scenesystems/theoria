{
  "name": "@theoria/theoria-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run server.ts",
    "dev:web": "vite --port 5175 --strictPort",
    "check": "tsc -b tsconfig.src.json",
    "check:tests": "tsc -b tsconfig.test.json",
    "check:all": "bun run check && bun run check:tests",
    "lint": "eslint --max-warnings=0 \"server.ts\" \"app/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\" \"vite.config.ts\" \"vitest.config.ts\"",
    "lint:fix": "eslint --max-warnings=0 --fix \"server.ts\" \"app/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\" \"vite.config.ts\" \"vitest.config.ts\"",
    "test": "vitest run --config vitest.config.ts",
    "build:web": "vite build",
    "build": "bun run gen:text-tokens && bun run check:all && bun run build:web",
    "gen:text-tokens": "bun scripts/generate-text-tokens.ts",
    "docgen": "echo 'docgen skipped for @theoria/theoria-app'",
    "test:e2e": "bun run --cwd ../.. test:e2e:theoria"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@effect-atom/atom": "^0.5.3",
    "@effect-atom/atom-react": "^0.5.0",
    "@effect/ai": "0.35.0",
    "@effect/platform": "0.96.0",
    "@effect/platform-bun": "0.89.0",
    "@effect/workflow": "0.18.0",
    "@heroicons/react": "^2.2.0",
    "@scenesystems/digest": "workspace:^",
    "@scenesystems/seal": "workspace:^",
    "@scenesystems/sign": "workspace:^",
    "effect": "3.21.0",
    "effect-dsp": "workspace:^",
    "effect-inference": "workspace:^",
    "effect-math": "workspace:^",
    "effect-search": "workspace:^",
    "effect-text": "workspace:^",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@theoria/source-proof": "workspace:*",
    "@effect/vitest": "^0.29.0",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "happy-dom": "^20.7.0",
    "tailwindcss": "^4.2.0",
    "vite": "^7.3.1"
  }
}
